{project, "egre"}.  % Optional, but nice for clarity

{erl_opts, [
    debug_info,
    warn_export_vars,
    warn_shadow_vars,
    warn_obsolete_guard,
    warnings_as_errors
    %% {parse_transform, gerlshmud_log_transform}
]}.

{deps, [
    jsx,
    epgsql,
    recon
]}.

%% Test-specific options (applied automatically when you run `rebar3 eunit`, `rebar3 ct`, etc.)
{profiles, [
    {test, [
        {erl_opts, [
            debug_info,
            warn_export_vars,
            warn_shadow_vars,
            warn_obsolete_guard
            %% {parse_transform, gerlshmud_log_transform}
        ]},
        {extra_src_dirs, ["test"]}   % equivalent to -pa test/ for test compilation
    ]}
]}.

%% If you still need to force certain modules to compile first (rarely needed in rebar3),
%% you can use the `compile_first` key at the top level:
%{compile_first, [egre_object, egre_rules]}.
